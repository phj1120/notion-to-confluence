{
  "name": "notion-to-confluence",
  "version": "1.0.0",
  "description": "Migrate Notion pages to Confluence with support for images, tables, code blocks, and more",
  "main": "migrate.py",
  "bin": {
    "notion-confluence": "./bin/notion-confluence"
  },
  "scripts": {
    "setup": "python3 -m pip install -r requirements.txt",
    "migrate": "python3 migrate.py",
    "init": "python3 bin/init_config.py",
    "schedule:start": "./scheduler_control.sh start",
    "schedule:stop": "./scheduler_control.sh stop",
    "schedule:status": "./scheduler_control.sh status",
    "schedule:logs": "./scheduler_control.sh logs"
  },
  "keywords": [
    "notion",
    "confluence",
    "migration",
    "atlassian",
    "documentation",
    "converter",
    "wiki"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/phj1120/notion-to-confluence.git"
  },
  "bugs": {
    "url": "https://github.com/phj1120/notion-to-confluence/issues"
  },
  "homepage": "https://github.com/phj1120/notion-to-confluence#readme",
  "engines": {
    "node": ">=14.0.0",
    "python": ">=3.7"
  },
  "files": [
    "src/",
    "bin/",
    "migrate.py",
    "scheduler_control.sh",
    "requirements.txt",
    "README.md",
    "LICENSE",
    "mapping.csv.example",
    ".env.example"
  ]
}
